{
  "name": "vite-react-typescript-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit_tests",
    "test:unit:watch": "vitest tests/unit_tests",
    "test:e2e": "cypress run",
    "test:e2e:open": "cypress open",
    "test:e2e:smoke": "cypress run --spec \"tests/e2e_tests/smoke/**/*.cy.ts\"",
    "test:e2e:smoke:open": "cypress open --e2e --spec \"tests/e2e_tests/smoke/**/*.cy.ts\"",
    "test:e2e:ci": "start-server-and-test dev http://localhost:5173 test:e2e",
    "test:e2e:smoke:ci": "start-server-and-test dev http://localhost:5173 test:e2e:smoke",
    "test:all": "npm run test:unit && npm run test:e2e"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^5.14.0",
    "@supabase/supabase-js": "^2.57.4",
    "@tanstack/react-query": "^5.0.0",
    "@types/pdfmake": "^0.3.2",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "file-saver": "^2.0.5",
    "lucide-react": "^0.344.0",
    "pdfmake": "^0.3.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.6.0",
    "react-pdf": "^10.4.1",
    "react-router-dom": "^6.20.0",
    "recharts": "^3.7.0",
    "tailwind-merge": "^3.5.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/file-saver": "^2.0.7",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/react-pdf": "^5.0.7",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "cypress": "^13.17.0",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "happy-dom": "^20.8.3",
    "jsdom": "^27.0.1",
    "postcss": "^8.4.35",
    "start-server-and-test": "^2.0.10",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^6.4.1",
    "vitest": "^4.0.18"
  }
}
